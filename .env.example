# Copy these into Vercel → Project → Settings → Environment Variables.
# (This file is only a template — never put real secrets in the repo.)

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# Google Apps Script web-app URL (ends in /exec) and its shared secret.
ORDERS_WEBHOOK_URL=
ORDERS_WEBHOOK_SECRET=

# Password your team uses to open /admin
ADMIN_PASSWORD=
